# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=your_mongodb_atlas_connection_string_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_this_to_a_random_string

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ─── Email Configuration ───────────────────────────────────────────
# Where contact-form notifications are delivered (your inbox).
ADMIN_EMAIL=your_email@example.com

# Owner display name (used in emails)
PORTFOLIO_OWNER_NAME=Your Name

# Email transport is chosen automatically by priority:
#   1) Brevo  (recommended — free, no domain needed)
#   2) Resend (fallback — needs a verified domain to email visitors)
#   3) SMTP   (local dev — Gmail etc.)

# Brevo (https://app.brevo.com → SMTP & API → API Keys)
BREVO_API_KEY=
# Must be an address verified under Brevo → Senders, Domains & Dedicated IPs
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Portfolio

# Resend (optional fallback)
RESEND_API_KEY=
EMAIL_FROM=

# SMTP (local dev only — Render blocks SMTP ports)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Notes:
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env to version control
# 3. Generate a strong JWT_SECRET using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 4. Get MongoDB URI from: https://www.mongodb.com/cloud/atlas
# 5. Get Cloudinary credentials from: https://cloudinary.com/console
